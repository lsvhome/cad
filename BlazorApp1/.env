# AI Provider Configuration
AI_PROVIDER=openai  # or 'ollama'

# OpenAI Configuration (required if AI_PROVIDER=openai)
OPENAI_API_KEY=github_lsvhome_asteroidswasm_OPENAI_API_KEY
