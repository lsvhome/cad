@page "/scad"
@using BlazorApp1.Services
@inject OpenScadModifier Modifier
@inject AppConfig Config
@rendermode InteractiveServer

<PageTitle>OpenSCAD Modifier</PageTitle>

<h2>OpenSCAD LLM Modifier</h2>
<p>AI Provider: <strong>@Config.AiProvider</strong></p>

<div class="row mb-3">
    <div class="col-md-6">
        <label class="form-label">Upload .scad file (optional)</label>
        <InputFile OnChange="OnFileSelected" accept=".scad" class="form-control" />
    </div>
</div>

<div class="mb-3">
    <label class="form-label">Modification prompt</label>
    <textarea class="form-control" rows="3" @bind="modificationPrompt"
              placeholder="e.g. Make it twice as large and add a hole in the center"></textarea>
</div>

<button class="btn btn-primary" @onclick="RunProcess" disabled="@isProcessing">
    @if (isProcessing)
    {
        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
        <span>Processing…</span>
    }
    else
    {
        <span>Process</span>
    }
</button>

@if (result is not null)
{
    <hr />
    @if (result.Success)
    {
        <div class="alert alert-success">Processing complete!</div>
    }
    else
    {
        <div class="alert alert-danger">@(result.ErrorMessage ?? "Processing failed.")</div>
    }

    @if (!string.IsNullOrEmpty(result.ScadFilePath))
    {
        <p><strong>SCAD file:</strong> @result.ScadFilePath</p>
    }
    @if (!string.IsNullOrEmpty(result.StlFilePath))
    {
        <p><strong>STL file:</strong> @result.StlFilePath</p>
    }

    @if (!string.IsNullOrEmpty(result.ModifiedScad))
    {
        <h5 class="mt-3">Modified SCAD Code</h5>
        <pre class="border rounded p-3 bg-light"><code>@result.ModifiedScad</code></pre>
    }
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="mt-2 text-muted">@statusMessage</div>
}

@code {
    private string? modificationPrompt;
    private IBrowserFile? selectedFile;
    private bool isProcessing;
    private ProcessResult? result;
    private string? statusMessage;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task RunProcess()
    {
        isProcessing = true;
        result = null;
        statusMessage = "Starting…";
        StateHasChanged();

        try
        {
            Stream? uploadStream = null;
            string? uploadFileName = null;

            if (selectedFile is not null)
            {
                statusMessage = "Uploading file…";
                StateHasChanged();
                uploadStream = selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                uploadFileName = selectedFile.Name;
            }

            statusMessage = "Processing with LLM…";
            StateHasChanged();

            result = await Modifier.ProcessAsync(
                inputFile: null,
                modification: modificationPrompt,
                uploadStream: uploadStream,
                uploadFileName: uploadFileName);

            statusMessage = null;
        }
        catch (Exception ex)
        {
            result = new ProcessResult { ErrorMessage = ex.Message };
        }
        finally
        {
            isProcessing = false;
        }
    }
}
